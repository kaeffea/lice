# This file documents the local environment contract. Do not copy it into the
# repository with real values. Run `make dev-env`; secrets are written with
# mode 0600 to ~/.config/lice/dev.env.

COMPOSE_PROJECT_NAME=lice
POSTGRES_SUPERUSER_PASSWORD=replace-with-a-random-value
LICE_MIGRATOR_PASSWORD=replace-with-a-random-value
LICE_RUNTIME_PASSWORD=replace-with-a-random-value
KEYCLOAK_DB_PASSWORD=replace-with-a-random-value
KEYCLOAK_BOOTSTRAP_ADMIN_CLIENT_ID=lice-local-bootstrap
KEYCLOAK_BOOTSTRAP_ADMIN_CLIENT_SECRET=replace-with-a-random-value
LICE_OIDC_CLIENT_SECRET=replace-with-a-random-value
LICE_SESSION_HASH_KEY=replace-with-64-lowercase-hex-characters
LICE_LOGIN_ENCRYPTION_KEY=replace-with-64-lowercase-hex-characters
LICE_CSRF_KEY=replace-with-64-lowercase-hex-characters
LICE_DEMO_OPERATOR_USERNAME=operator@lice.local
LICE_DEMO_OPERATOR_PASSWORD=replace-with-a-random-value
LICE_DEMO_VIEWER_USERNAME=viewer@lice.local
LICE_DEMO_VIEWER_PASSWORD=replace-with-a-random-value
