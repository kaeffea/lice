{
	admin off
	auto_https off
}

:8080 {
	route {
		@proxy_health path /_proxy/health
		respond @proxy_health 200

		@identity host auth.lice.localhost
		handle @identity {
			reverse_proxy keycloak:8080
		}

		@application host lice.localhost
		handle @application {
			header {
				-Server
				Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self'; font-src 'self'; form-action 'self' http://auth.lice.localhost:8080; frame-ancestors 'none'; img-src 'self' data:; object-src 'none'; script-src 'self'; style-src 'self'"
				Cross-Origin-Opener-Policy "same-origin"
				Cross-Origin-Resource-Policy "same-origin"
				Permissions-Policy "camera=(), geolocation=(), microphone=()"
				Referrer-Policy "same-origin"
				X-Content-Type-Options "nosniff"
				X-Frame-Options "DENY"
			}

			@api path /api/* /health/*
			handle @api {
				reverse_proxy api:8080 {
					header_up X-Lice-Client-IP {http.request.remote.host}
				}
			}

			handle {
				reverse_proxy web:3000
			}
		}

		respond 404
	}
}
